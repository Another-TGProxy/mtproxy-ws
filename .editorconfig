root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{vala,vapi}]
indent_style = space
indent_size = 4

[*.{c,h}]
indent_style = space
indent_size = 4

[*.blp]
indent_style = space
indent_size = 2

[{meson.build,meson.options,meson_options.txt}]
indent_style = space
indent_size = 2

[*.{json,css,xml}]
indent_style = space
indent_size = 2
